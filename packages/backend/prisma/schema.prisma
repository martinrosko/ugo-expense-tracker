generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── User (mirrored from Keycloak on first login) ─────────────────────────────

model User {
  id             String        @id            // Keycloak subject UUID
  email          String        @unique
  name           String
  businessUnit   BusinessUnit? @relation(fields: [businessUnitId], references: [id])
  businessUnitId String?
  accounts       Account[]
  plans          Plan[]
  tags           Tag[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model BusinessUnit {
  id        String   @id @default(uuid())
  name      String
  users     User[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Accounts ─────────────────────────────────────────────────────────────────

model Account {
  id             String      @id @default(uuid())
  name           String
  type           AccountType
  initialBalance Decimal     @default(0) @db.Decimal(18, 4)
  isDefault      Boolean     @default(false)
  stateCode      Int         @default(0) /// 0 = Active, 1 = Inactive
  statusCode     Int         @default(0)
  owner          User        @relation(fields: [ownerId], references: [id])
  ownerId        String

  bankTickets       BankTicket[]
  fromTransactions  Transaction[] @relation("TxFromAccount")
  toTransactions    Transaction[] @relation("TxToAccount")
  defaultForBudgets Budget[]      @relation("BudgetDefaultAccount")
  defaultForPlans   Plan[]        @relation("PlanDefaultAccount")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum AccountType {
  CASH
  BANK
  INVESTMENT
  PAYMENT_PARTNER
}

// ─── Plans & Budgets ──────────────────────────────────────────────────────────

model Plan {
  id                String           @id @default(uuid())
  name              String?
  startDate         DateTime?        @db.Date
  endDate           DateTime?        @db.Date
  intervalType      PlanIntervalType
  recurrenceConfig  String?          /// JSON string from rw_recurrenceconfig
  isTemplate        Boolean          @default(false)
  stateCode         Int              @default(0) /// 0 = Active, 1 = Inactive
  statusCode        Int              @default(0) /// 0=Draft 1=Active 2=Scheduled 3=Completed 4=Cancelled
  template          Plan?            @relation("PlanFromTemplate", fields: [templateId], references: [id])
  templateId        String?
  instances         Plan[]           @relation("PlanFromTemplate")
  defaultAccount    Account?         @relation("PlanDefaultAccount", fields: [defaultAccountId], references: [id])
  defaultAccountId  String?
  owner             User             @relation(fields: [ownerId], references: [id])
  ownerId           String
  budgets           Budget[]
  transactions      Transaction[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

enum PlanIntervalType {
  ONE_TIME
  WEEKLY
  MONTHLY
  YEARLY
}

model Budget {
  id               String   @id @default(uuid())
  name             String?
  amount           Decimal? @db.Decimal(18, 4)
  stateCode        Int      @default(0)
  statusCode       Int      @default(0)
  plan             Plan     @relation(fields: [planId], references: [id])
  planId           String
  defaultAccount   Account? @relation("BudgetDefaultAccount", fields: [defaultAccountId], references: [id])
  defaultAccountId String?
  template         Budget?  @relation("BudgetFromTemplate", fields: [templateId], references: [id])
  templateId       String?
  instances        Budget[] @relation("BudgetFromTemplate")
  transactions     Transaction[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ─── Bank Tickets (raw bank statement rows) ───────────────────────────────────

model BankTicket {
  id                   String   @id @default(uuid())
  name                 String?
  amount               Decimal  @db.Decimal(18, 4)
  executedOn           DateTime
  partnerName          String?
  partnerAccountNumber String?
  reference            String?
  variableSymbol       String?
  constantSymbol       String?
  specificSymbol       String?
  stateCode            Int      @default(0)
  statusCode           Int      @default(0)
  /// Bank-assigned transaction ID — used for deduplication
  ticketId             String?
  account              Account  @relation(fields: [accountId], references: [id])
  accountId            String
  transaction          Transaction?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  /// Prevent importing the same bank row twice for the same account
  @@unique([accountId, ticketId])
}

// ─── Transactions ─────────────────────────────────────────────────────────────

model Transaction {
  id            String          @id @default(uuid())
  name          String?
  amount        Decimal?        @db.Decimal(18, 4)
  plannedAmount Decimal?        @db.Decimal(18, 4)
  plannedOn     DateTime?
  executedOn    DateTime?
  dueDateConfig String?
  type          TransactionType
  stateCode     Int             @default(0)
  statusCode    Int             @default(0)
  bankTicket    BankTicket?     @relation(fields: [bankTicketId], references: [id])
  bankTicketId  String?         @unique
  budget        Budget?         @relation(fields: [budgetId], references: [id])
  budgetId      String?
  plan          Plan?           @relation(fields: [planId], references: [id])
  planId        String?
  fromAccount   Account?        @relation("TxFromAccount", fields: [fromAccountId], references: [id])
  fromAccountId String?
  toAccount     Account?        @relation("TxToAccount", fields: [toAccountId], references: [id])
  toAccountId   String?
  template      Transaction?    @relation("TxFromTemplate", fields: [templateId], references: [id])
  templateId    String?
  instances     Transaction[]   @relation("TxFromTemplate")
  tags          TransactionTag[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

enum TransactionType {
  TRANSACTION
  BALANCE
}

// ─── Tags ─────────────────────────────────────────────────────────────────────

model Tag {
  id           String           @id @default(uuid())
  name         String
  color        String?
  stateCode    Int              @default(0)
  statusCode   Int              @default(0)
  owner        User             @relation(fields: [ownerId], references: [id])
  ownerId      String
  transactions TransactionTag[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

model TransactionTag {
  id            String      @id @default(uuid())
  transaction   Transaction @relation(fields: [transactionId], references: [id])
  transactionId String
  tag           Tag         @relation(fields: [tagId], references: [id])
  tagId         String
  amount        Decimal?    @db.Decimal(18, 4)
  createdAt     DateTime    @default(now())

  @@unique([transactionId, tagId])
}
